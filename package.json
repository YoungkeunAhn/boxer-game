{
  "name": "boxer-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "granite dev",
    "build": "ait build",
    "dev:web": "vite",
    "build:web": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:verify": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:fast": "node tools/check.mjs fast",
    "check:plan": "node tools/check.mjs plan",
    "check:all": "node tools/check.mjs full",
    "check:e2e": "node tools/check.mjs full && playwright test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "2.9.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.14"
  }
}
